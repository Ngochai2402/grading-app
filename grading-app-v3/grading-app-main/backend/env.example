ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=your_gemini_api_key
PORT=3001

# Tùy chọn: override model OCR (mặc định gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-pro
# GEMINI_MODEL=gemini-2.0-flash

# PDF export: mặc định dùng HTML auto-print qua trình duyệt (ổn định, không
# phụ thuộc service ngoài). Bật LaTeX chỉ khi có service compile riêng:
# LATEX_ENABLED=1
# LATEX_SERVICE_URL=https://your-xelatex-service/compile
